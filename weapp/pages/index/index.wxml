<view class="container theme-{{themeMode}}">
  <!-- 顶部装饰背景 -->
  <view class="header-bg">
    <view class="header-gradient"></view>
    <view class="header-pattern">✦</view>
  </view>

  <!-- 顶部信息栏 -->
  <view class="header">
    <view class="header-content">
      <view class="logo-section">
        <text class="logo-icon">🤖</text>
        <view class="logo-text">
          <text class="app-name">小帅 AI 日报</text>
          <text class="app-slogan">跟着小帅，每日读懂 AI 前沿</text>
        </view>
      </view>
      <view class="header-actions">
        <view class="theme-btn" bindtap="onThemeTap">
          <text class="theme-btn-icon">{{themeIcon}}</text>
        </view>
        <view class="date-section" bindtap="onDateTap">
          <text class="date-icon">📅</text>
          <text class="date-text">{{currentDate}}</text>
          <text class="date-arrow">▼</text>
        </view>
      </view>
    </view>
    <view class="stats-bar">
      <view class="stat-item">
        <text class="stat-icon">📊</text>
        <text class="stat-text">共 {{newsCount}} 条资讯</text>
      </view>
      <view class="stat-item">
        <text class="stat-icon">⚡</text>
        <text class="stat-text">实时更新</text>
      </view>
    </view>
  </view>

  <!-- 资讯列表 -->
  <view class="news-list">
    <block wx:for="{{newsList}}" wx:key="id">
      <view class="news-card animate-fade-in" bindtap="onNewsTap" data-id="{{item.id}}" style="animation-delay: {{index * 0.1}}s">
        <!-- 卡片顶部装饰线 -->
        <view class="card-accent"></view>
        
        <!-- 来源和时间 -->
        <view class="card-header">
          <view class="source-tag">
            <text class="source-icon">🔹</text>
            <text class="source-name">{{item.source_name}}</text>
          </view>
          <view class="time-tag">
            <text class="time-icon">🕐</text>
            <text class="time-text">{{item.publish_date}}</text>
          </view>
        </view>

        <!-- 标题 -->
        <text class="news-title">{{item.title}}</text>

        <!-- 摘要预览 -->
        <view class="summary-preview" wx:if="{{item.summary}}">
          <text class="summary-icon">✨</text>
          <text class="summary-text">{{item.summary}}</text>
        </view>

        <!-- 底部标签 -->
        <view class="card-footer">
          <view class="category-tag" wx:if="{{item.category}}">
            <text class="category-icon">🏷️</text>
            <text>{{item.category}}</text>
          </view>
          <view class="read-more">
            <text>阅读更多</text>
            <text class="arrow">→</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner">✨</view>
    <text class="loading-text">正在加载资讯...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && newsList.length === 0}}">
    <text class="empty-icon">🔍</text>
    <text class="empty-title">暂无资讯</text>
    <text class="empty-desc">该日期暂时没有AI相关资讯，请尝试其他日期</text>
  </view>

  <!-- 底部装饰 -->
  <view class="footer-decoration">
    <text>✦ 已加载全部内容 ✦</text>
  </view>

  <!-- 日期选择器弹窗 -->
  <view class="picker-mask" wx:if="{{showDatePicker}}" bindtap="onCloseDatePicker"></view>
  <view class="picker-content" wx:if="{{showDatePicker}}">
    <view class="picker-header">
      <text class="picker-title">📅 选择日期</text>
      <view class="picker-close" bindtap="onCloseDatePicker">✕</view>
    </view>
    <view class="picker-body">
      <view 
        class="picker-item {{item === currentDate ? 'active' : ''}}" 
        wx:for="{{dateList}}" 
        wx:key="*this"
        bindtap="onDateSelect"
        data-index="{{index}}"
      >
        <text class="picker-item-text">{{item}}</text>
        <text class="picker-item-check" wx:if="{{item === currentDate}}">✓</text>
      </view>
    </view>
  </view>
</view>
