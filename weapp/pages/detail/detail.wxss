/* ========================
   基础容器 & 白天模式 (默认)
   ======================== */
.container {
  padding: 0 32rpx 60rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
}

/* ========================
   夜晚模式
   ======================== */
.container.theme-night {
  background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
}

.container.theme-night .nav-bar {
  background: rgba(15, 23, 42, 0.9);
}

.container.theme-night .nav-back {
  background: rgba(99, 102, 241, 0.2);
}

.container.theme-night .nav-icon,
.container.theme-night .nav-text {
  color: #818cf8;
}

.container.theme-night .article-title {
  color: #e2e8f0;
}

.container.theme-night .meta-source {
  background: rgba(99, 102, 241, 0.2);
  color: #818cf8;
}

.container.theme-night .meta-time {
  background: rgba(6, 182, 212, 0.2);
  color: #22d3ee;
}

.container.theme-night .content-card {
  background: #1e293b;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

.container.theme-night .content-badge .badge-text {
  color: #e2e8f0;
}

.container.theme-night .content-text {
  color: #94a3b8;
}

.container.theme-night .action-btn {
  background: #1e293b;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

.container.theme-night .action-text {
  color: #94a3b8;
}

.container.theme-night .btn-share .action-text {
  color: #818cf8;
}

.container.theme-night .btn-link .action-text {
  color: #22d3ee;
}

.container.theme-night .article-footer .footer-line,
.container.theme-night .article-footer .footer-text {
  color: #475569;
}

/* ========================
   护眼模式
   ======================== */
.container.theme-eye {
  background: linear-gradient(180deg, #f5f0e6 0%, #ede6d6 100%);
}

.container.theme-eye .nav-bar {
  background: rgba(245, 240, 230, 0.9);
}

.container.theme-eye .nav-back {
  background: rgba(139, 119, 91, 0.15);
}

.container.theme-eye .nav-icon,
.container.theme-eye .nav-text {
  color: #8b775b;
}

.container.theme-eye .article-title {
  color: #3d3225;
}

.container.theme-eye .meta-source {
  background: rgba(139, 119, 91, 0.15);
  color: #8b775b;
}

.container.theme-eye .meta-time {
  background: rgba(107, 142, 35, 0.15);
  color: #6b8e23;
}

.container.theme-eye .summary-card {
  background: linear-gradient(135deg, #8b9a6d 0%, #7a8a5a 100%);
  box-shadow: 0 8rpx 32rpx rgba(139, 154, 109, 0.25);
}

.container.theme-eye .content-card {
  background: #faf6ee;
  box-shadow: 0 4px 20px rgba(139, 119, 91, 0.08);
}

.container.theme-eye .content-card::before {
  background: linear-gradient(180deg, #8b9a6d, #6b8e23);
}

.container.theme-eye .content-badge .badge-text {
  color: #3d3225;
}

.container.theme-eye .content-text {
  color: #5c4f3a;
}

.container.theme-eye .action-btn {
  background: #faf6ee;
  box-shadow: 0 4px 20px rgba(139, 119, 91, 0.08);
}

.container.theme-eye .action-text {
  color: #8b775b;
}

.container.theme-eye .btn-share .action-text {
  color: #8b775b;
}

.container.theme-eye .btn-link .action-text {
  color: #6b8e23;
}

.container.theme-eye .article-footer .footer-line,
.container.theme-eye .article-footer .footer-text {
  color: #b8a88a;
}

/* ========================
   顶部导航栏
   ======================== */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  margin: 0 -32rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
  position: sticky;
  top: 0;
  background: rgba(248, 250, 252, 0.9);
  backdrop-filter: blur(20px);
  z-index: 10;
}

.nav-back {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  background: rgba(99, 102, 241, 0.1);
  border-radius: 50rpx;
  transition: all 0.3s;
}

.nav-back:active {
  background: rgba(99, 102, 241, 0.2);
  transform: scale(0.98);
}

.nav-icon {
  font-size: 32rpx;
  color: var(--primary);
}

.nav-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary);
}

.nav-actions {
  display: flex;
  gap: 16rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  border-radius: 50%;
  box-shadow: var(--shadow);
  transition: all 0.3s;
}

.nav-btn:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-lg);
}

.nav-btn-icon {
  font-size: 28rpx;
}

/* ========================
   文章头部
   ======================== */
.article-header {
  margin: 32rpx 0 40rpx;
}

.article-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.meta-source,
.meta-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 24rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
}

.meta-source {
  background: rgba(99, 102, 241, 0.1);
  color: var(--primary);
}

.meta-time {
  background: rgba(6, 182, 212, 0.1);
  color: var(--secondary);
}

.meta-icon {
  font-size: 22rpx;
}

.meta-text {
  font-weight: 500;
}

.article-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.4;
  letter-spacing: 2rpx;
}

/* ========================
   AI 摘要卡片
   ======================== */
.summary-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.25);
}

.summary-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.summary-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 28rpx;
  border-radius: 50rpx;
  backdrop-filter: blur(10px);
}

.badge-icon {
  font-size: 28rpx;
}

.badge-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}

.summary-decoration {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.3);
}

.summary-body {
  position: relative;
  z-index: 1;
  margin-bottom: 24rpx;
}

.summary-content {
  font-size: 30rpx;
  color: #fff;
  line-height: 1.7;
  font-weight: 500;
}

.summary-footer {
  display: flex;
  justify-content: flex-end;
  position: relative;
  z-index: 1;
}

.summary-tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.15);
  padding: 8rpx 20rpx;
  border-radius: 50rpx;
}

/* ========================
   原文内容卡片
   ======================== */
.content-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: var(--shadow);
  position: relative;
  overflow: hidden;
}

.content-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(180deg, var(--secondary), var(--primary));
}

.content-header {
  margin-bottom: 28rpx;
  padding-left: 20rpx;
}

.content-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.content-badge .badge-icon {
  font-size: 32rpx;
}

.content-badge .badge-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.content-body {
  padding-left: 20rpx;
}

.content-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  text-align: justify;
}

/* ========================
   操作栏 - 紧凑按钮
   ======================== */
.action-bar {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 48rpx;
  padding: 0 20rpx;
}

.action-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
  background: var(--bg-card);
  box-shadow: var(--shadow);
  transition: all 0.3s;
  flex: none;
}

.action-btn:active {
  transform: translateY(-2rpx);
  box-shadow: var(--shadow-lg);
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.btn-share .action-text {
  color: var(--primary);
}

.btn-link .action-text {
  color: var(--secondary);
}

.btn-favorite .action-text {
  color: var(--text-muted);
}

.btn-favorite.active .action-text {
  color: #f59e0b;
}

/* ========================
   底部装饰
   ======================== */
.article-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 40rpx 0;
}

.footer-line {
  font-size: 24rpx;
  color: var(--text-muted);
  opacity: 0.5;
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-muted);
  letter-spacing: 8rpx;
  font-weight: 600;
}

/* ========================
   加载状态
   ======================== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-spinner {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* ========================
   弹框
   ======================== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(8px);
  z-index: 100;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 82%;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  z-index: 101;
  padding: 48rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.modal-icon {
  font-size: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.link-box {
  background: #f1f5f9;
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 32rpx;
  word-break: break-all;
}

.link-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.modal-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx;
  border-radius: var(--radius);
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.modal-btn:active {
  transform: scale(0.98);
}

.btn-copy {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.3);
}

.btn-close {
  background: #f1f5f9;
  color: var(--text-secondary);
}

.btn-icon {
  font-size: 28rpx;
}
